{
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "functions": {
    "api/cron/**": {
      "maxDuration": 60
    },
    "api/stream/**": {
      "maxDuration": 30
    },
    "api/admin/providers/health/**": {
      "maxDuration": 60
    }
  }
}
